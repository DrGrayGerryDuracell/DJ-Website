{
  "buildCommand": "npm run verify",
  "outputDirectory": ".",
  "cleanUrls": false,
  "trailingSlash": false,
  "redirects": [
    {
      "source": "/(.*)",
      "has": [
        {
          "type": "host",
          "value": "www.drgray-mrsdrgray.com"
        }
      ],
      "destination": "https://drgray-mrsdrgray.com/$1",
      "permanent": true
    },
    {
      "source": "/dashboard",
      "destination": "/control",
      "permanent": true
    }
  ],
  "headers": [
    {
      "source": "/control/(.*)",
      "headers": [
        { "key": "X-Robots-Tag", "value": "noindex, nofollow" }
      ]
    },
    {
      "source": "/control-login.html",
      "headers": [
        { "key": "X-Robots-Tag", "value": "noindex, nofollow" }
      ]
    }
  ]
}
