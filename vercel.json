{
  "cleanUrls": false,
  "trailingSlash": false,
  "redirects": [
    {
      "source": "/dashboard",
      "destination": "/control",
      "permanent": true
    }
  ],
  "headers": [
    {
      "source": "/control/(.*)",
      "headers": [
        { "key": "X-Robots-Tag", "value": "noindex, nofollow" }
      ]
    }
  ]
}
