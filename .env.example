# Dashboard Data Source
DASHBOARD_DATA_MODE=mock

# Optional future integrations (leave empty for now)
PUBLIC_ANALYTICS_ENDPOINT=
PUBLIC_SHOP_METRICS_ENDPOINT=
PUBLIC_SOCIAL_METRICS_ENDPOINT=

# Optional TikTok Live API tokens (recommended for real follower/video/like data)
TIKTOK_DR_ACCESS_TOKEN=
TIKTOK_MRS_ACCESS_TOKEN=

# Optional monitoring toggles
ENABLE_LINK_HEALTH_CHECK=true
ENABLE_ACTIVITY_FEED_MOCK=true
